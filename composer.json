{
    "name": "akonsta/d5-design-system-helper",
    "description": "WordPress plugin: export, import, audit, and manage your Divi 5 design system — variables, presets, layouts, pages, theme customizer, and builder templates",
    "authors": [
        {
            "name": "Andrew Konstantaras",
            "email": "konsta@me2we.com",
            "role": "Developer"
        }
    ],
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1",
        "erusev/parsedown-extra": "^0.9.0",
        "phpoffice/phpspreadsheet": "^2.1",
        "yahnis-elsts/plugin-update-checker": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10"
    },
    "autoload": {
        "psr-4": {
            "D5DesignSystemHelper\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "D5DesignSystemHelper\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "vendor-dir": "vendor",
        "platform-check": false,
        "platform": {
            "php": "8.1.0"
        }
    },
    "scripts": {
        "install-deps": "composer install --no-dev --optimize-autoloader",
        "install-dev":  "composer install --optimize-autoloader"
    }
}
